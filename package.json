{
  "name": "eight2five-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "modules/expo-kbeaconpro",
    "modules/expo-pans-ble-api"
  ],
  "scripts": {
    "start:mobile": "npm run start --workspace apps/mobile",
    "start:testbed": "npm run start --workspace apps/testbed",
    "android:mobile": "npm run android --workspace apps/mobile",
    "android:testbed": "npm run android --workspace apps/testbed",
    "ios:mobile": "npm run ios --workspace apps/mobile",
    "ios:testbed": "npm run ios --workspace apps/testbed",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "validate:core": "npm run type-check && npm run lint && npm run test",
    "validate:expo:doctor": "npm run --workspace apps/mobile expo:doctor && npm run --workspace apps/testbed expo:doctor",
    "validate:expo:install-check": "npm run --workspace apps/mobile expo:install-check && npm run --workspace apps/testbed expo:install-check",
    "validate": "npm run validate:core && npm run validate:expo:doctor && npm run validate:expo:install-check",
    "agent:validate": "node .github/scripts/agent-validate.cjs",
    "agent:commit:note": "node .github/scripts/agent-commit-note.cjs",
    "agent:commit:from-note": "node .github/scripts/agent-commit-from-note.cjs",
    "agent:commit:archive": "node .github/scripts/agent-commit-archive.cjs"
  }
}
