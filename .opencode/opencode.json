{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-codebase-index"
  ],
  "default_agent": "engineer",
  "permission": {
    "websearch": "allow",
    "lsp": "allow"
  },
  "tools": {
    "websearch": true,
    "lsp": true
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    }
  },
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "engineer": {
      "prompt": "{file:./agents/engineer.md}",
      "temperature": 0.5
    },
    "explore": {
      "prompt": "{file:./agents/explore.md}",
      "temperature": 0.3
    },
    "general": {
      "prompt": "{file:./agents/general.md}",
      "temperature": 0.1
    }
  }
}